{
  "name": "4mica",
  "private": true,
  "imports": {
    "#*": "./src/*"
  },
  "keywords": [],
  "type": "module",
  "exports": null,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/4mica-Network/homepage.git"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "biome check .",
    "test": "turbo run test",
    "lint:write": "biome check --write --diagnostic-level=error .",
    "lint:linter": "biome lint --write --diagnostic-level=error .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@4mica/tsconfig": "workspace:*",
    "@types/node": "catalog:node24",
    "@types/npm-registry-fetch": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "changelogen": "catalog:",
    "esbuild": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "ky": "catalog:",
    "lint-staged": "catalog:",
    "ora": "catalog:",
    "picocolors": "catalog:",
    "rimraf": "catalog:",
    "taze": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:typescript-latest",
    "vitest": "catalog:",
    "yargs": "catalog:"
  },
  "engines": {
    "node": "^14.18.0 || >=16.10.0"
  },
  "pkg": {
    "outputPath": "./package/"
  },
  "packageManager": "pnpm@10.28.2",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@biomejs/cli-darwin-x64": "catalog:",
    "execa": "catalog:",
    "find-up": "catalog:",
    "npm-registry-fetch": "catalog:",
    "read-pkg": "catalog:",
    "terminal-link": "catalog:"
  }
}
